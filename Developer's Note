### 5. ICS generation – `buildICS(events)`

```js
function buildICS(events) {
  const lines = [];
  lines.push('BEGIN:VCALENDAR');
  lines.push('VERSION:2.0');
  lines.push('PRODID:-//obsidian-daily-notes-to-ics//EN');
  lines.push('CALSCALE:GREGORIAN');
  lines.push('METHOD:PUBLISH');

  const now = new Date();
  const dtStamp = toICSDateTime(now);

  for (const ev of events) {
    const uid =
      'obsidian-' +
      ev.start.getTime().toString(36) +
      '-' +
      Math.random().toString(36).slice(2);

    lines.push('BEGIN:VEVENT');
    lines.push('UID:' + uid);
    lines.push('DTSTAMP:' + dtStamp);
    lines.push('DTSTART:' + toICSDateTime(ev.start));
    lines.push('DTEND:' + toICSDateTime(ev.end));
    lines.push('SUMMARY:' + icsEscape(ev.summary));
    if (ev.location) {
      lines.push('LOCATION:' + icsEscape(ev.location));
    }
    if (ev.description) {
      lines.push('DESCRIPTION:' + icsEscape(ev.description));
    }
    lines.push('END:VEVENT');
  }

  lines.push('END:VCALENDAR');
  return lines.join('\r\n');
}
```

- Uses “floating” local times (no explicit timezone).
- Escapes characters that would break ICS syntax.

To add all‑day events, you could branch on tasks without time and emit `DTSTART;VALUE=DATE:YYYYMMDD`.

