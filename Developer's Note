## Key functions

### 1. `dateFromFilename(name)`

```js
function dateFromFilename(name) {
  const base = name.replace(/\.md$/i, '');
  const m = base.match(/(\d{4})\s(\\d{2})(\\d{2})/);
  if (!m) return null;
  const [_, y, mo, d] = m;
  return { year: Number(y), month: Number(mo), day: Number(d) };
}
```

- Expects filenames like `2026 0115.md`.
- Returns `{ year, month, day }` or `null` if it does not match.

To support different patterns, adjust the regex and capture groups.

---

### 2. Time parsing helpers

```js
function parseCompactTime(str) {
  const s = str.trim();
  if (!/^\d{3,4}$/.test(s)) return null;
  let h, m;
  if (s.length === 3) {
    h = Number(s);
    m = Number(s.slice(1));
  } else {
    h = Number(s.slice(0, 2));
    m = Number(s.slice(2));
  }
  if (Number.isNaN(h) || Number.isNaN(m) || h < 0 || h > 23 || m < 0 || m > 59) {
    return null;
  }
  return { h, m };
}

function makeDateTime(dateObj, compact) {
  const t = parseCompactTime(compact);
  if (!t) return null;
  return new Date(
    dateObj.year,
    dateObj.month - 1,
    dateObj.day,
    t.h,
    t.m,
    0,
    0
  );
}
```

- Interprets `900` as 09:00, `0115` as 01:15, `1700` as 17:00 on the given date.
- Returns a JavaScript `Date` instance in local time.

